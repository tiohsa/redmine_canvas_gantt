<fieldset class="box tabular">
  <legend>Canvas Gantt - Inline Quick Edit (Level 2+)</legend>

  <p>
    <label><%= l(:field_subject) %></label>
    <%= check_box_tag 'settings[inline_edit_subject]', '1', settings['inline_edit_subject'].to_s == '1' %>
  </p>

  <p>
    <label><%= l(:field_assigned_to) %></label>
    <%= check_box_tag 'settings[inline_edit_assigned_to]', '1', settings['inline_edit_assigned_to'].to_s == '1' %>
  </p>

  <p>
    <label><%= l(:field_status) %></label>
    <%= check_box_tag 'settings[inline_edit_status]', '1', settings['inline_edit_status'].to_s == '1' %>
  </p>

  <p>
    <label><%= l(:field_done_ratio) %></label>
    <%= check_box_tag 'settings[inline_edit_done_ratio]', '1', settings['inline_edit_done_ratio'].to_s == '1' %>
  </p>

  <p>
    <label><%= l(:field_due_date) %></label>
    <%= check_box_tag 'settings[inline_edit_due_date]', '1', settings['inline_edit_due_date'].to_s == '1' %>
  </p>

  <p>
    <label><%= l(:label_custom_field_plural) %> (default ON)</label>
    <%= check_box_tag 'settings[inline_edit_custom_fields]', '1', settings.fetch('inline_edit_custom_fields', '1').to_s == '1' %>
  </p>


  <p>
    <label>Default relation type</label>
    <%= select_tag 'settings[default_relation_type]', options_for_select([['precedes', 'precedes'], ['relates', 'relates'], ['blocks', 'blocks']], settings.fetch('default_relation_type', 'precedes').to_s) %>
  </p>

  <p>
    <label>Auto calculate relation delay</label>
    <%= check_box_tag 'settings[auto_calculate_delay]', '1', settings.fetch('auto_calculate_delay', '1').to_s == '1' %>
  </p>

  <p>
    <label>Dependency edit mode default ON</label>
    <%= check_box_tag 'settings[dependency_edit_mode]', '1', settings.fetch('dependency_edit_mode', '1').to_s == '1' %>
  </p>
  <p>
    <label><%= l(:label_row_height) %></label>
    <%= number_field_tag 'settings[row_height]', settings['row_height'], min: 20, max: 100 %>
  </p>
</fieldset>
